{
  "name": "datewise",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev --workspace @datewise/web",
    "dev:api": "npm run dev --workspace @datewise/api",
    "build": "npm run build --workspace @datewise/shared && npm run build --workspace @datewise/api && npm run build --workspace @datewise/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1"
  }
}
