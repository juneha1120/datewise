{
  "name": "@datewise/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "npm run clean && npm run build --workspace @datewise/shared && nest start --watch",
    "build": "npm run clean && npm run build --workspace @datewise/shared && nest build",
    "start": "node dist/main.js",
    "typecheck": "npm run build --workspace @datewise/shared && tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.spec.js\""
  },
  "dependencies": {
    "@datewise/shared": "1.0.0",
    "@nestjs/common": "^10.4.9",
    "@nestjs/core": "^10.4.9",
    "@nestjs/platform-express": "^10.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
